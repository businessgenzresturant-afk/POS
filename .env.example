# Environment Variables for Gen-Z Restaurant POS
# Copy this file to .env and fill in your actual values

# ============================================
# LOCAL DEVELOPMENT
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/restaurant_pos?schema=public"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# PRODUCTION (Neon PostgreSQL + Vercel)
# ============================================
# Get connection string from Neon Dashboard → Connection Details

# ⚠️ IMPORTANT: Use POOLED connection for production!
# Pooled Connection (RECOMMENDED for serverless)
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:6543/neondb?sslmode=require"

# OR with pgbouncer parameter (alternative format)
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1&sslmode=require"

# ❌ DO NOT USE: Direct connection in production (causes "max clients" error)
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"

# Direct Connection (only for migrations, not for app runtime)
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"

# Production URL
# NEXTAUTH_URL="https://pos.gen-z.online"

# ============================================
# SECURITY
# ============================================
# Generate new secret: openssl rand -base64 32
# MUST be different in production!
NEXTAUTH_SECRET="vW8xK3mN9pQ2rT5yU7zA4bC6dE8fG0hJ2kL4mN6pQ8s"

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Tax rate (18% GST in India)
TAX_RATE="0.18"

# UPI ID for QR code payments
# NEXT_PUBLIC_UPI_ID="genzrestaurant@paytm"
