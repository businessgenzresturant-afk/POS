generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Restaurant {
  id        String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String
  address   String
  createdAt DateTime   @default(now())
  menuItems MenuItem[]
  tables    Table[]
  users     User[]
}

model Table {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  number       Int
  capacity     Int
  status       TableStatus @default(AVAILABLE)
  restaurantId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  bills        Bill[]
  orders       Order[]
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([status])
}

model MenuItem {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  name         String
  category     String
  price        Float
  imageUrl     String
  available    Boolean     @default(true)
  restaurantId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  orderItems   OrderItem[]

  @@index([restaurantId])
  @@index([category])
  @@index([available])
}

model Order {
  id            String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  tableId       String
  status        OrderStatus   @default(PENDING)
  totalAmount   Float         @default(0)
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  customerName  String?
  customerPhone String?
  bill          Bill?
  table         Table         @relation(fields: [tableId], references: [id])
  items         OrderItem[]

  @@index([tableId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id                  String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId             String
  menuItemId          String
  quantity            Int
  price               Float
  specialInstructions String?
  menuItem            MenuItem @relation(fields: [menuItemId], references: [id])
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
}

model Bill {
  id            String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  orderId       String     @unique
  tableId       String
  subtotal      Float
  tax           Float
  discount      Float      @default(0)
  total         Float
  status        BillStatus @default(PENDING)
  paymentMethod String?
  createdAt     DateTime   @default(now())
  paidAt        DateTime?
  order         Order      @relation(fields: [orderId], references: [id])
  table         Table      @relation(fields: [tableId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model User {
  id           String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  email        String      @unique
  password     String
  name         String
  role         Role        @default(STAFF)
  restaurantId String?
  createdAt    DateTime    @default(now())
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum BillStatus {
  PENDING
  PAID
  CANCELLED
}

enum Role {
  ADMIN
  STAFF
}
